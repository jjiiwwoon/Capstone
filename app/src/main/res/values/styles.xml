<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- 🔹 바텀 네비게이션 버튼 스타일 -->
    <style name="BottomNavButton">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">?attr/selectableItemBackground</item>
        <item name="android:textColor">#000000</item>
        <item name="android:paddingHorizontal">16dp</item>
        <item name="android:paddingVertical">8dp</item>
        <item name="android:minWidth">80dp</item>
    </style>

    <!-- 🔹 커스텀 다이얼로그 스타일 -->
    <style name="CustomDialog" parent="Theme.AppCompat.Dialog">
        <item name="android:windowBackground">@drawable/dialog_background</item>
        <item name="android:backgroundDimEnabled">true</item>
    </style>

    <style name="MyFeatureButtonStyle" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="cornerRadius">16dp</item>
        <item name="backgroundTint">#42A5F5</item> <!-- 밝은 파랑 -->
        <item name="android:padding">12dp</item>
        <item name="android:elevation">4dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:layout_marginEnd">4dp</item>
    </style>




    <!-- 🔹 프로필 라벨 (항목명) -->
    <style name="ProfileLabel">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">#666666</item>
    </style>

    <!-- 🔹 프로필 값 (항목 내용) -->
    <style name="ProfileValue">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">#000000</item>
    </style>

    <!-- 🔹 프로필 항목 구분선 -->
    <style name="ProfileDivider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1.2dp</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:layout_marginBottom">8dp</item>
        <item name="android:background">#DDDDDD</item>
    </style>

    <!-- 🔹 라운드 버튼 (하늘색) -->
    <style name="RoundedCyanButton" parent="Widget.Material3.Button">
        <item name="android:background">@drawable/bg_button_rounded</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:padding">12dp</item>
        <item name="android:elevation">4dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:layout_marginTop">16dp</item>
    </style>

    <!-- ✅ 새로 추가된: 항목을 감싸는 카드 박스 스타일 -->
    <style name="ProfileItemBox">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:background">#FFFFFF</item>
        <item name="android:padding">16dp</item>
        <item name="android:layout_marginBottom">10dp</item>
        <item name="android:layout_marginHorizontal">12dp</item>
        <item name="android:elevation">2dp</item>
        <item name="android:gravity">center_vertical</item>
    </style>

    <style name="ProfileBadgeFixed">
        <item name="android:background">@drawable/bg_round_badge</item>
        <item name="android:textColor">#333333</item>
        <item name="android:textSize">15sp</item>
        <item name="android:gravity">center</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingHorizontal">16dp</item>
        <item name="android:paddingVertical">10dp</item>
    </style>

    <style name="RoundedImageStyle" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item> <!-- 원형 / 또는 8dp로 조절 가능 -->
    </style>

    <!-- 기록 셀 공통 스타일 -->
    <style name="RecordCellBase">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">48dp</item>      <!-- 동일 높이 -->
        <item name="android:layout_weight">1</item>         <!-- 균등 너비 -->
        <item name="android:gravity">center</item>          <!-- 가로/세로 중앙 -->
        <item name="android:includeFontPadding">false</item>
        <item name="android:singleLine">true</item>
        <item name="android:ellipsize">end</item>
        <!-- 필요 시 테두리/배경 스타일을 여기에 추가 -->
    </style>

    <style name="RecordCellHeader" parent="RecordCellBase">
        <item name="android:textStyle">bold</item>
    </style>

    <style name="RecordCellValue" parent="RecordCellBase">
        <item name="android:textSize">15sp</item>
    </style>

    <!-- 더 자연스러운 대비용 -->
    <style name="SpecLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">10dp</item>
        <!-- 11sp → 13sp : 살짝 키움 -->
        <item name="android:textSize">13sp</item>
        <!-- #94A3B8 → #6B7280(slate-500) : 조금 더 진하게 -->
        <item name="android:textColor">#6B7280</item>
    </style>

    <style name="SpecValue">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">end</item>
        <!-- 16sp → 15sp : 1sp 낮춤 -->
        <item name="android:textSize">15sp</item>
        <!-- bold → 미디엄(가독성 좋고 과하지 않음) -->
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textStyle">normal</item>
        <!-- #0F172A → #1F2937(slate-800) : 명암 살짝 완화 -->
        <item name="android:textColor">#1F2937</item>
        <!-- 미세 간격으로 답답함 줄이기 -->
        <item name="android:letterSpacing">0.01</item>
    </style>

</resources>
