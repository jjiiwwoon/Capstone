<?xml version="1.0" encoding="utf-8"?>
<com.example.myapp.StateLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/stateLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:loadingLayout="@layout/view_state_loading"
    app:emptyLayout="@layout/view_state_empty">

    <!-- ✅ 기존 NestedScrollView를 그대로 안으로 넣기 -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/recordsRoot"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        android:fillViewport="true"
        android:background="#F7F9FC"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== 팀기록 (전적 + 팀 득실 기록) ===== -->
            <TextView
                android:id="@+id/tvTeamStatsTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="팀기록"
                android:textColor="#111111"
                android:textStyle="bold"
                android:textSize="16sp"
                android:paddingStart="16dp"
                android:paddingEnd="8dp"
                android:layout_marginTop="24dp" />

            <androidx.cardview.widget.CardView
                android:id="@+id/teamStatsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                app:cardUseCompatPadding="true"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- 전적 요약 (제목행) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="5"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="경기"
                            android:textColor="#666666"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="승"
                            android:textColor="@color/win"
                            android:textStyle="bold"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="무"
                            android:textColor="@color/draw"
                            android:textStyle="bold"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="패"
                            android:textColor="@color/loss"
                            android:textStyle="bold"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="승률"
                            android:textColor="#666666"
                            android:gravity="center" />
                    </LinearLayout>

                    <!-- 전적 요약 (값행) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="5">

                        <TextView
                            android:id="@+id/tvGames"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textStyle="bold"
                            android:textColor="#111111"
                            android:gravity="center" />

                        <TextView
                            android:id="@+id/tvWins"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textStyle="bold"
                            android:textColor="@color/win"
                            android:gravity="center" />

                        <TextView
                            android:id="@+id/tvDraws"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textStyle="bold"
                            android:textColor="@color/draw"
                            android:gravity="center" />

                        <TextView
                            android:id="@+id/tvLosses"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textStyle="bold"
                            android:textColor="@color/loss"
                            android:gravity="center" />

                        <TextView
                            android:id="@+id/tvWinRate"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="0%"
                            android:textStyle="bold"
                            android:textColor="#333333"
                            android:gravity="center" />
                    </LinearLayout>

                    <!-- 구분선 -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="8dp"
                        android:background="#E0E0E0" />

                    <!-- 팀 득실 -->
                    <TextView
                        android:id="@+id/tvTeamGfGaHeader"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="팀 득실 기록"
                        android:textColor="#333333"
                        android:textSize="13sp"
                        android:layout_marginBottom="6dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:weightSum="3"
                            android:layout_marginBottom="4dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:text="득점"
                                android:textStyle="bold"
                                android:textColor="@color/goal_for"
                                android:gravity="center" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:text="실점"
                                android:textStyle="bold"
                                android:textColor="@color/goal_against"
                                android:gravity="center" />

                            <TextView
                                android:id="@+id/tvGoalDiffTitle"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:text="득실차"
                                android:textColor="#666666"
                                android:gravity="center" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:weightSum="3">

                            <TextView
                                android:id="@+id/tvTotalGoalsFor"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textStyle="bold"
                                android:textColor="@color/goal_for"
                                android:gravity="center" />

                            <TextView
                                android:id="@+id/tvTotalGoalsAgainst"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textStyle="bold"
                                android:textColor="@color/goal_against"
                                android:gravity="center" />

                            <TextView
                                android:id="@+id/tvGoalDiff"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textStyle="bold"
                                android:textColor="#111111"
                                android:gravity="center" />
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ===== 개인기록 (좌우 배치) ===== -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp" />

            <TextView
                android:id="@+id/tvPersonalTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="개인기록"
                android:textColor="#111111"
                android:textStyle="bold"
                android:textSize="16sp"
                android:paddingStart="16dp"
                android:paddingEnd="8dp"
                android:layout_marginBottom="8dp" />

            <!-- ▶ 득점/도움 TOP3 나란히 배치 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="8dp">

                <!-- ▶ 득점/도움 TOP3 나란히 배치 (수정본) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:layout_marginBottom="8dp">

                    <!-- ◀ 득점 TOP3 카드 -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/goalsTop3Card"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="4dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="4dp"
                        app:cardUseCompatPadding="true">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="득점 TOP3"
                                android:textStyle="bold"
                                android:textColor="#333333"
                                android:textSize="14sp" />

                            <LinearLayout
                                android:id="@+id/topScorersContainer"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:weightSum="3"
                                android:paddingTop="6dp"
                                android:paddingBottom="4dp">

                                <!-- 2위 -->
                                <LinearLayout
                                    android:id="@+id/top2Row"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:gravity="center_horizontal"
                                    android:orientation="vertical"
                                    android:layout_marginTop="6dp">

                                    <!-- 왕관 -->
                                    <ImageView
                                        android:id="@+id/crownTop2"
                                        android:layout_width="22dp"
                                        android:layout_height="14dp"
                                        android:layout_marginBottom="4dp"
                                        android:src="@drawable/crown_silver" />

                                    <!-- 프로필 -->
                                    <com.google.android.material.imageview.ShapeableImageView
                                        android:id="@+id/imageTop2"
                                        android:layout_width="40dp"
                                        android:layout_height="40dp"
                                        android:scaleType="centerCrop"
                                        app:shapeAppearanceOverlay="@style/RoundedImageStyle" />

                                    <!-- 이름 -->
                                    <TextView
                                        android:id="@+id/tvTop2Name"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="4dp"
                                        android:text="닉네임"
                                        android:textSize="12sp"
                                        android:textColor="#111111" />

                                    <!-- 득점 수 -->
                                    <TextView
                                        android:id="@+id/tvTop2Goals"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="0골"
                                        android:textSize="12sp"
                                        android:textColor="#666666" />
                                </LinearLayout>

                                <!-- 1위 -->
                                <LinearLayout
                                    android:id="@+id/top1Row"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:gravity="center_horizontal"
                                    android:orientation="vertical">

                                    <!-- 왕관 -->
                                    <ImageView
                                        android:id="@+id/crownTop1"
                                        android:layout_width="26dp"
                                        android:layout_height="16dp"
                                        android:layout_marginBottom="4dp"
                                        android:src="@drawable/crown_gold" />

                                    <!-- 프로필 -->
                                    <com.google.android.material.imageview.ShapeableImageView
                                        android:id="@+id/imageTop1"
                                        android:layout_width="50dp"
                                        android:layout_height="50dp"
                                        android:scaleType="centerCrop"
                                        app:shapeAppearanceOverlay="@style/RoundedImageStyle" />

                                    <!-- 이름 -->
                                    <TextView
                                        android:id="@+id/tvTop1Name"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="4dp"
                                        android:text="닉네임"
                                        android:textSize="12sp"
                                        android:textColor="#111111"
                                        android:textStyle="bold" />

                                    <!-- 득점 수 -->
                                    <TextView
                                        android:id="@+id/tvTop1Goals"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="0골"
                                        android:textSize="12sp"
                                        android:textColor="#111111"
                                        android:textStyle="bold" />
                                </LinearLayout>

                                <!-- 3위 -->
                                <LinearLayout
                                    android:id="@+id/top3Row"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:gravity="center_horizontal"
                                    android:orientation="vertical"
                                    android:layout_marginTop="10dp">

                                    <!-- 왕관 -->
                                    <ImageView
                                        android:id="@+id/crownTop3"
                                        android:layout_width="22dp"
                                        android:layout_height="14dp"
                                        android:layout_marginBottom="4dp"
                                        android:src="@drawable/crown_bronze" />

                                    <!-- 프로필 -->
                                    <com.google.android.material.imageview.ShapeableImageView
                                        android:id="@+id/imageTop3"
                                        android:layout_width="40dp"
                                        android:layout_height="40dp"
                                        android:scaleType="centerCrop"
                                        app:shapeAppearanceOverlay="@style/RoundedImageStyle" />

                                    <!-- 이름 -->
                                    <TextView
                                        android:id="@+id/tvTop3Name"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="4dp"
                                        android:text="닉네임"
                                        android:textSize="12sp"
                                        android:textColor="#111111" />

                                    <!-- 득점 수 -->
                                    <TextView
                                        android:id="@+id/tvTop3Goals"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="0골"
                                        android:textSize="12sp"
                                        android:textColor="#666666" />
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- ▶ 도움 TOP3 카드 -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/assistsTop3Card"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="4dp"
                        app:cardUseCompatPadding="true">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="도움 TOP3"
                                android:textStyle="bold"
                                android:textColor="#333333"
                                android:textSize="14sp" />

                            <LinearLayout
                                android:id="@+id/topAssistsContainer"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:weightSum="3"
                                android:paddingTop="6dp"
                                android:paddingBottom="4dp">

                                <!-- 도움 2위 -->
                                <LinearLayout
                                    android:id="@+id/assistTop2Row"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:gravity="center_horizontal"
                                    android:orientation="vertical"
                                    android:layout_marginTop="6dp">

                                    <ImageView
                                        android:id="@+id/crownAssist2"
                                        android:layout_width="22dp"
                                        android:layout_height="14dp"
                                        android:layout_marginBottom="4dp"
                                        android:src="@drawable/crown_silver" />

                                    <com.google.android.material.imageview.ShapeableImageView
                                        android:id="@+id/imageAssistTop2"
                                        android:layout_width="40dp"
                                        android:layout_height="40dp"
                                        android:scaleType="centerCrop"
                                        app:shapeAppearanceOverlay="@style/RoundedImageStyle" />

                                    <TextView
                                        android:id="@+id/tvAssistTop2Name"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="4dp"
                                        android:text="닉네임"
                                        android:textSize="12sp"
                                        android:textColor="#111111" />

                                    <TextView
                                        android:id="@+id/tvAssistTop2Count"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="0도움"
                                        android:textSize="12sp"
                                        android:textColor="#666666" />
                                </LinearLayout>

                                <!-- 도움 1위 -->
                                <LinearLayout
                                    android:id="@+id/assistTop1Row"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:gravity="center_horizontal"
                                    android:orientation="vertical">

                                    <ImageView
                                        android:id="@+id/crownAssist1"
                                        android:layout_width="26dp"
                                        android:layout_height="16dp"
                                        android:layout_marginBottom="4dp"
                                        android:src="@drawable/crown_gold" />

                                    <com.google.android.material.imageview.ShapeableImageView
                                        android:id="@+id/imageAssistTop1"
                                        android:layout_width="50dp"
                                        android:layout_height="50dp"
                                        android:scaleType="centerCrop"
                                        app:shapeAppearanceOverlay="@style/RoundedImageStyle" />

                                    <TextView
                                        android:id="@+id/tvAssistTop1Name"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="4dp"
                                        android:text="닉네임"
                                        android:textSize="12sp"
                                        android:textColor="#111111"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:id="@+id/tvAssistTop1Count"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="0도움"
                                        android:textSize="12sp"
                                        android:textColor="#111111"
                                        android:textStyle="bold" />
                                </LinearLayout>

                                <!-- 도움 3위 -->
                                <LinearLayout
                                    android:id="@+id/assistTop3Row"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:gravity="center_horizontal"
                                    android:orientation="vertical"
                                    android:layout_marginTop="10dp">

                                    <ImageView
                                        android:id="@+id/crownAssist3"
                                        android:layout_width="22dp"
                                        android:layout_height="14dp"
                                        android:layout_marginBottom="4dp"
                                        android:src="@drawable/crown_bronze" />

                                    <com.google.android.material.imageview.ShapeableImageView
                                        android:id="@+id/imageAssistTop3"
                                        android:layout_width="40dp"
                                        android:layout_height="40dp"
                                        android:scaleType="centerCrop"
                                        app:shapeAppearanceOverlay="@style/RoundedImageStyle" />

                                    <TextView
                                        android:id="@+id/tvAssistTop3Name"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="4dp"
                                        android:text="닉네임"
                                        android:textSize="12sp"
                                        android:textColor="#111111" />

                                    <TextView
                                        android:id="@+id/tvAssistTop3Count"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="0도움"
                                        android:textSize="12sp"
                                        android:textColor="#666666" />
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>


            </LinearLayout>

            <!-- ▼▼▼ 개인기록(고정/스크롤) 새 구조 ▼▼▼ -->
            <LinearLayout
                android:id="@+id/personalTableRoot"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:layout_marginTop="8dp">

                <!-- ◀ 왼쪽 고정열: 헤더(순위) + 리스트 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.4"
                    android:orientation="vertical">

                    <!-- 왼쪽 헤더(순위/닉네임 영역 타이틀) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:gravity="center_vertical"
                        android:background="#E5E7EB"
                        android:paddingStart="10dp">
                        <TextView
                            android:id="@+id/hRank"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="순위"
                            android:textStyle="bold"
                            android:textColor="#424242"/>
                    </LinearLayout>

                    <!-- 왼쪽 리스트(순위·프로필·닉네임) -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvPersonalLeft"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"/>
                </LinearLayout>

                <!-- ▶ 오른쪽 스크롤 영역: 헤더 + 리스트를 같은 HS 안에 넣음 -->
                <HorizontalScrollView
                    android:id="@+id/metricsScroll"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.6"
                    android:overScrollMode="never"
                    android:fillViewport="true"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/metricsContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- 오른쪽 헤더(경기/득점/도움/공격P) -->
                        <LinearLayout
                            android:id="@+id/personalHeader"
                            android:layout_width="wrap_content"
                            android:layout_height="44dp"
                            android:orientation="horizontal"
                            android:background="#E5E7EB"
                            android:gravity="center_vertical"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp">

                            <!-- 경기 -->
                            <LinearLayout
                                android:id="@+id/hGames"
                                android:layout_width="78dp"
                                android:layout_height="32dp"
                                android:gravity="center"
                                android:orientation="horizontal"
                                android:clickable="true"
                                android:focusable="true"
                                android:foreground="?attr/selectableItemBackground">

                                <TextView
                                    android:id="@+id/tvHdrGames"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="경기"
                                    android:textStyle="bold"
                                    android:textColor="#424242"/>

                                <ImageView
                                    android:id="@+id/icHdrGames"
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:layout_marginStart="4dp"
                                    android:src="@drawable/ic_arrow_up"
                                    android:alpha="0.0"/>
                            </LinearLayout>

                            <!-- 득점 -->
                            <LinearLayout
                                android:id="@+id/hGoals"
                                android:layout_width="78dp"
                                android:layout_height="32dp"
                                android:gravity="center"
                                android:orientation="horizontal"
                                android:clickable="true"
                                android:focusable="true"
                                android:foreground="?attr/selectableItemBackground">

                                <TextView
                                    android:id="@+id/tvHdrGoals"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="득점"
                                    android:textStyle="bold"
                                    android:textColor="@color/goal_for"/>

                                <ImageView
                                    android:id="@+id/icHdrGoals"
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:layout_marginStart="4dp"
                                    android:src="@drawable/ic_arrow_up"/>
                            </LinearLayout>

                            <!-- 도움 -->
                            <LinearLayout
                                android:id="@+id/hAssists"
                                android:layout_width="78dp"
                                android:layout_height="32dp"
                                android:gravity="center"
                                android:orientation="horizontal"
                                android:clickable="true"
                                android:focusable="true"
                                android:foreground="?attr/selectableItemBackground">

                                <TextView
                                    android:id="@+id/tvHdrAssists"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="도움"
                                    android:textStyle="bold"
                                    android:textColor="#424242"/>

                                <ImageView
                                    android:id="@+id/icHdrAssists"
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:layout_marginStart="4dp"
                                    android:src="@drawable/ic_arrow_up"
                                    android:alpha="0.0"/>
                            </LinearLayout>

                            <!-- 공격P -->
                            <LinearLayout
                                android:id="@+id/hAttackP"
                                android:layout_width="78dp"
                                android:layout_height="32dp"
                                android:gravity="center"
                                android:orientation="horizontal"
                                android:clickable="true"
                                android:focusable="true"
                                android:foreground="?attr/selectableItemBackground">

                                <TextView
                                    android:id="@+id/tvHdrAttackP"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="공격P"
                                    android:textStyle="bold"
                                    android:textColor="#424242"/>

                                <ImageView
                                    android:id="@+id/icHdrAttackP"
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:layout_marginStart="4dp"
                                    android:src="@drawable/ic_arrow_up"
                                    android:alpha="0.0"/>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- 오른쪽 리스트(경기/득점/도움/공격P) — 헤더와 같은 HS 내부 -->
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvPersonalRight"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false"
                            android:clipToPadding="false"
                            android:paddingBottom="8dp"/>
                    </LinearLayout>
                </HorizontalScrollView>
            </LinearLayout>
            <!-- ▲▲▲ 개인기록 새 구조 끝 ▲▲▲ -->

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp" />

            <TextView
                android:id="@+id/tvPrevTitle"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="8dp"
                android:text="이전 시합 기록 보기"
                android:textStyle="bold"
                android:textColor="#111111"
                android:textSize="16sp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recordsRecycler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:clipToPadding="false"
                android:paddingBottom="4dp" />

            <LinearLayout
                android:id="@+id/layoutLoadMore"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:layout_marginTop="4dp"
                android:clickable="true"
                android:foreground="?attr/selectableItemBackground">
                <ImageView
                    android:id="@+id/iconLoadMore"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_arrow_down" />
                <TextView
                    android:id="@+id/tvLoadMore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  더 보기"
                    android:textColor="#111111"
                    android:textStyle="bold"
                    android:textSize="14sp" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</com.example.myapp.StateLayout>
