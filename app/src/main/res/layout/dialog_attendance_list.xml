<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/attendanceRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="16dp"
    android:paddingBottom="16dp"
    android:background="#F7F9FC">

    <ProgressBar
        android:id="@+id/progressAttendance"
        style="?android:attr/progressBarStyleSmall"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_gravity="end"
        android:visibility="gone" />

    <!-- 참석자 -->
    <TextView
        android:id="@+id/tvAttendHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="참석자 (0)"
        android:textStyle="bold"
        android:textSize="15sp"
        android:textColor="@color/goal_for"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="6dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvAttend"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <!-- 중간 선 (좌우 여백 있는 구분선) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:background="#E3E5E9" />

    <!-- 불참자 -->
    <TextView
        android:id="@+id/tvAbsentHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="불참자 (0)"
        android:textStyle="bold"
        android:textSize="15sp"
        android:textColor="@color/loss"
        android:layout_marginBottom="6dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvAbsent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <!-- 구분선 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:background="#E3E5E9" />

    <!-- 미투표자 -->
    <TextView
        android:id="@+id/tvNotVotedHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="미투표자 (0)"
        android:textStyle="bold"
        android:textSize="15sp"
        android:textColor="@color/draw"
        android:layout_marginBottom="6dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvNotVoted"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <!-- 빈 상태 -->
    <TextView
        android:id="@+id/tvEmptyAttendance"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="여기에 참석/불참/미투표 명단이 표시됩니다."
        android:textSize="13sp"
        android:textColor="#6B7280"
        android:gravity="center"
        android:paddingTop="16dp"
        android:paddingBottom="8dp"
        android:visibility="gone" />
</LinearLayout>
