<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F7F7 ">

    <!-- 기존 LinearLayout 전체를 감싼 메인 컨텐츠 -->
    <LinearLayout
        android:id="@+id/mainContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- 🔍 검색 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_margin="12dp"
            android:layout_marginBottom="8dp">

            <EditText
                android:id="@+id/editTeamSearch"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_searchbox"
                android:drawableStart="@drawable/ic_search"
                android:hint="팀 이름 검색"
                android:paddingHorizontal="12dp"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- 📦 필터 영역 -->
        <!-- 📦 필터 영역 -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginHorizontal="12dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingEnd="8dp">

                <!-- 🌍 활동 지역 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginEnd="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="활동 지역"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />

                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">

                        <!-- 시/도 -->
                        <LinearLayout
                            android:id="@+id/btnCity"
                            android:layout_width="wrap_content"
                            android:layout_height="35dp"
                            android:orientation="horizontal"
                            android:paddingHorizontal="12dp"
                            android:background="@drawable/bg_filter_chip"
                            android:gravity="center_vertical"
                            android:layout_marginEnd="4dp"
                            android:clickable="true"
                            android:focusable="true">

                            <TextView
                                android:id="@+id/textCity"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="전체"
                                android:textColor="#000000"
                                android:textSize="13sp" />

                            <ImageView
                                android:id="@+id/iconCityArrow"
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_arrow_down"
                                android:layout_marginStart="4dp"
                                app:tint="#000000" />
                        </LinearLayout>

                        <!-- 구/군 -->
                        <LinearLayout
                            android:id="@+id/btnDistrict"
                            android:layout_width="wrap_content"
                            android:layout_height="35dp"
                            android:orientation="horizontal"
                            android:paddingHorizontal="12dp"
                            android:background="@drawable/bg_filter_chip"
                            android:gravity="center_vertical"
                            android:layout_marginEnd="4dp"
                            android:clickable="true"
                            android:focusable="true">

                            <TextView
                                android:id="@+id/textDistrict"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="전체"
                                android:textColor="#000000"
                                android:textSize="13sp" />

                            <ImageView
                                android:id="@+id/iconDistrictArrow"
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_arrow_down"
                                android:layout_marginStart="4dp"
                                app:tint="#000000" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- 💪 실력 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginEnd="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="실력"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />

                    <LinearLayout
                        android:id="@+id/btnSkill"
                        android:layout_width="wrap_content"
                        android:layout_height="35dp"
                        android:orientation="horizontal"
                        android:paddingHorizontal="12dp"
                        android:background="@drawable/bg_filter_chip"
                        android:gravity="center_vertical"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:id="@+id/textSkill"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="전체"
                            android:textColor="#000000"
                            android:textSize="13sp" />

                        <ImageView
                            android:id="@+id/iconSkillArrow"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_arrow_down"
                            android:layout_marginStart="4dp"
                            app:tint="#000000" />
                    </LinearLayout>
                </LinearLayout>

                <!-- 👥 나이대 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="연령대"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />

                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">

                        <!-- 나이 시작 -->
                        <LinearLayout
                            android:id="@+id/btnAgeStart"
                            android:layout_width="wrap_content"
                            android:layout_height="35dp"
                            android:orientation="horizontal"
                            android:paddingHorizontal="12dp"
                            android:background="@drawable/bg_filter_chip"
                            android:gravity="center_vertical"
                            android:layout_marginEnd="4dp"
                            android:clickable="true"
                            android:focusable="true">

                            <TextView
                                android:id="@+id/textAgeStart"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="전체"
                                android:textColor="#000000"
                                android:textSize="13sp" />

                            <ImageView
                                android:id="@+id/iconAgeStartArrow"
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_arrow_down"
                                android:layout_marginStart="4dp"
                                app:tint="#000000" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="~"
                            android:textSize="16sp"
                            android:textColor="#000000"
                            android:layout_marginEnd="4dp"
                            android:gravity="center_vertical" />

                        <!-- 나이 끝 -->
                        <LinearLayout
                            android:id="@+id/btnAgeEnd"
                            android:layout_width="wrap_content"
                            android:layout_height="35dp"
                            android:orientation="horizontal"
                            android:paddingHorizontal="12dp"
                            android:background="@drawable/bg_filter_chip"
                            android:gravity="center_vertical"
                            android:clickable="true"
                            android:focusable="true">

                            <TextView
                                android:id="@+id/textAgeEnd"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="전체"
                                android:textColor="#000000"
                                android:textSize="13sp" />

                            <ImageView
                                android:id="@+id/iconAgeEndArrow"
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_arrow_down"
                                android:layout_marginStart="4dp"
                                app:tint="#000000" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </HorizontalScrollView>

        <!-- 📋 팀 리스트 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewTeams"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_margin="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:contentDescription="팀 목록"
            android:padding="0dp"
            tools:listitem="@layout/team_item" />
    </LinearLayout>

    <!-- ✅ 오른쪽 하단 FloatingActionButton 추가 -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnCreateTeam"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_margin="16dp"
        android:contentDescription="팀 만들기"
        app:srcCompat="@drawable/ic_add_white"
        app:tint="#FFFFFF"
        app:backgroundTint="#0ed7ed" />
</RelativeLayout>
