<?xml version="1.0" encoding="utf-8"?>
<!-- 채팅방 셀: 카드형 + 라운드 + 리플, 프로필은 정사각형에 모서리만 둥글게 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingLeft="12dp"
    android:paddingRight="12dp"
    android:paddingTop="6dp">

    <!-- 카드 컨테이너: FrameLayout으로 바꿔서 우측 상단에 뱃지/시간 오버레이 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="76dp"
        android:padding="12dp"
        android:background="@drawable/bg_chat_item"
        android:foreground="?attr/selectableItemBackground">

        <!-- 본문(프로필 + 가운데 텍스트들). 우측에 시간/뱃지 공간 확보 위해 end padding 추가 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingEnd="56dp">

            <!-- ✅ 라운드된 프로필 이미지 -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imageProfile"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginEnd="12dp"
                android:scaleType="centerCrop"
                android:contentDescription="프로필 이미지"
                app:shapeAppearanceOverlay="@style/RoundedImageStyle" />

            <!-- 가운데: 닉네임 + 마지막 메시지 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/textNickname"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="상대 닉네임"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="#111111" />

                <TextView
                    android:id="@+id/textLastMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="마지막 메시지"
                    android:textSize="14sp"
                    android:textColor="#6B6B6B"
                    android:ellipsize="end"
                    android:maxLines="1" />
            </LinearLayout>
        </LinearLayout>

        <!-- 우측 상단: 미읽음 뱃지 (기본 숨김) -->
        <TextView
            android:id="@+id/unreadBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="18dp"
            android:minHeight="18dp"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="@drawable/bg_badge_red"
            android:visibility="gone"
            android:contentDescription="미읽음 메시지 수"
            android:layout_gravity="end|top"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="6dp" />

        <!-- 우측: 시간 (뱃지 아래로 약간 내림) -->
        <TextView
            android:id="@+id/textTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="top|end"
            android:text="오전 1:23"
            android:textSize="12sp"
            android:textColor="#9E9E9E"
            android:layout_gravity="end|top"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="28dp" />

    </FrameLayout>
</LinearLayout>
