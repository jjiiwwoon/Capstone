<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <RelativeLayout
        android:id="@+id/itemRoot"
        android:layout_width="match_parent"
        android:layout_height="128dp"
        android:padding="12dp"
        android:foreground="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <!-- 좌측: 로고 + 팀명 (세로 중앙) -->
        <LinearLayout
            android:id="@+id/leftColumn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:orientation="vertical">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imageTeamLogo"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_launcher_foreground"
                app:shapeAppearanceOverlay="@style/RoundedImageStyle" />

            <TextView
                android:id="@+id/textTeamName"
                android:layout_width="64dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:text=""
                android:textColor="#111111"
                android:textSize="12.5sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- ✅ 우상단: 모집유형 배지 -->
        <TextView
            android:id="@+id/textRecruitType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="용병"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:includeFontPadding="false"
            android:background="@drawable/bg_badge_member" />

        <!-- 우측 내용 -->
        <LinearLayout
            android:id="@+id/rightLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_toEndOf="@id/leftColumn"
            android:layout_toStartOf="@id/textRecruitType"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <!-- 날짜 | 시간 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/textDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2025-10-29"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:textColor="#2C2C2C" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" | "
                    android:layout_marginHorizontal="6dp"
                    android:textSize="14sp"
                    android:textColor="#9AA0A6" />

                <TextView
                    android:id="@+id/textTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="22:00 ~ 22:10"
                    android:textSize="14sp"
                    android:textColor="#4A4A4A" />
            </LinearLayout>

            <!-- 주소: 1줄만 -->
            <TextView
                android:id="@+id/textStadium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="ff | 대한민국 서울특별시 중구 태평로1가 31-33"
                android:textSize="13sp"
                android:textColor="#444444"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- 실력 -->
            <TextView
                android:id="@+id/textSkill"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="실력 : 0 ~ 10"
                android:textSize="13sp"
                android:textColor="#444444" />

            <!-- 모집 포지션: 단일 줄, 넘치면 스크롤 -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:scrollbars="none"
                android:fillViewport="false">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupPositions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleLine="true"
                    app:singleSelection="false"
                    app:chipSpacingHorizontal="6dp"
                    app:chipSpacingVertical="0dp" />
            </HorizontalScrollView>

            <!-- 남는 공간 채우기 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"/>
        </LinearLayout>

        <!-- 우하단: 작성 시각 -->
        <TextView
            android:id="@+id/textTimestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_alignParentEnd="true"
            android:text="1일 전"
            android:textSize="12sp"
            android:textColor="#9E9E9E" />
    </RelativeLayout>

    <!-- 구분선 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EDEDED"/>
</LinearLayout>
