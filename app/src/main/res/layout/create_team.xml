<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:padding="16dp"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <!-- 상단 제목 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="팀 만들기"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- 팀 엠블럼 -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imageTeamLogo"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginBottom="12dp"
            android:scaleType="centerCrop"
            android:background="#E0E0E0"
            android:src="@drawable/ic_shield_gray"
            app:shapeAppearanceOverlay="@style/RoundedImageStyle" />

        <!-- 사진 선택 버튼 (밝은 색 계열) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSelectLogo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="사진 선택"
            android:minHeight="40dp"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="24dp"
            app:cornerRadius="12dp"
            app:backgroundTint="#2196F3" />

        <!-- 팀 이름 -->
        <EditText
            android:id="@+id/editTeamName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/rounded_input_light"
            android:hint="팀 이름"
            android:minHeight="40dp"
            android:padding="8dp" />

        <!-- 활동 지역 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="활동 지역"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#000000"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp"
            android:weightSum="2">

            <Spinner
                android:id="@+id/spinnerCity"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="@drawable/rounded_input_light" />

            <Space
                android:layout_width="8dp"
                android:layout_height="wrap_content" />

            <Spinner
                android:id="@+id/spinnerDistrict"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="@drawable/rounded_input_light" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#DDDDDD" />

        <!-- ===== 활동 장소 (텍스트형 입력 구조) ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"

            android:paddingVertical="4dp">

            <!-- 설명 텍스트 (얇은 굵기) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="활동 장소 :"
                android:textStyle="normal"
                android:textSize="15sp"
                android:textColor="#444444"
                android:layout_marginEnd="8dp" />

            <!-- 간단 입력형 EditText -->
            <EditText
                android:id="@+id/editStadiumName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="주로 활동하는 장소를 입력해주세요"
                android:inputType="textCapSentences"
                android:textColor="#000000"
                android:textSize="15sp"
                android:padding="4dp" />
        </LinearLayout>

        <!-- ===== 주소(기존 유지) 섹션 - 안내 텍스트가 주소 표시를 겸함 ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <!-- 안내 텍스트(= 주소 표시부). 선택 후 이곳 텍스트가 실제 주소로 바뀜 -->
            <TextView
                android:id="@+id/editStadium"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="활동장소의 주소를 등록할 수 있습니다"
                android:textSize="13sp"
                android:textColor="#666666"
                android:ellipsize="end"
                android:singleLine="true"
                android:paddingEnd="8dp" />

            <!-- 버튼 텍스트 변경: '주소 등록' -->
            <Button
                android:id="@+id/btnSearchStadium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:minHeight="0dp"
                android:padding="4dp"
                android:text="주소 등록"
                android:textColor="#2196F3"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- 활동일 및 시간 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="활동일"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="#000000" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:text="시간"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="#000000" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3"
                android:gravity="center_vertical">

                <Spinner
                    android:id="@+id/spinnerActivityDay"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@drawable/rounded_input_light" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="40dp"
                    android:layout_marginHorizontal="8dp"
                    android:background="#CCCCCC" />

                <Spinner
                    android:id="@+id/spinnerTimeStart"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@drawable/rounded_input_light" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" ~ "
                    android:textSize="16sp"
                    android:textColor="#000000"
                    android:layout_marginHorizontal="6dp" />

                <Spinner
                    android:id="@+id/spinnerTimeEnd"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@drawable/rounded_input_light" />
            </LinearLayout>
        </LinearLayout>

        <!-- 나이대 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="나이대"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#000000"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <Spinner
                android:id="@+id/spinnerAgeStart"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="40dp"
                android:background="@drawable/rounded_input_light" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" ~ "
                android:gravity="center"
                android:layout_marginHorizontal="8dp" />

            <Spinner
                android:id="@+id/spinnerAgeEnd"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="40dp"
                android:background="@drawable/rounded_input_light" />
        </LinearLayout>

        <!-- 회비 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="회비"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#000000"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/editFee"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="회비(월) 예: 30000"
            android:inputType="number"
            android:minHeight="40dp"
            android:padding="8dp"
            android:background="@drawable/rounded_input_light"
            android:layout_marginBottom="16dp" />

        <!-- 팀 소개 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="팀 소개"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#000000"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/editTeamIntro"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:minHeight="200dp"
            android:hint="자유롭게 팀에 대한 설명을 입력해주세요"
            android:gravity="top|start"
            android:padding="8dp"
            android:inputType="textMultiLine"
            android:overScrollMode="always"
            android:scrollbars="vertical"
            android:fadingEdgeLength="8dp"
            android:background="@drawable/rounded_input_light" />

        <!-- 저장 버튼 (밝은 색 계열) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveTeam"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="팀 생성"
            android:minHeight="44dp"
            android:layout_marginTop="20dp"
            android:textColor="#FFFFFF"
            app:cornerRadius="12dp"
            app:backgroundTint="#2196F3" />
    </LinearLayout>
</ScrollView>
