<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nextScheduleCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:clickable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeColor="#E8EEF5"
    app:strokeWidth="1dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <ProgressBar
            android:id="@+id/scheduleLoading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/scheduleContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- 상단 날짜칩 -->
            <!-- view_next_schedule_card.xml -->
            <TextView
                android:id="@+id/tvNextDateChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/bg_date_chip"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:text="2025.11.02 (일) · 18:00 ~ 21:00"
            android:textColor="#0D47A1"
            android:textSize="13sp"
            android:textStyle="normal"
            android:maxLines="1"
            android:ellipsize="end" />


            <!-- 로고 / 스코어 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:orientation="horizontal">

                <!-- 홈팀 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/imgHomeLogo"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:scaleType="centerCrop"
                        android:contentDescription="홈 팀 로고"
                        android:src="@drawable/ic_placeholder_circle"
                        app:shapeAppearanceOverlay="@style/RoundedImageStyle"
                        app:strokeColor="@android:color/transparent" />

                    <TextView
                        android:id="@+id/tvHomeName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Team7"
                        android:textColor="#111827"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:gravity="center" />
                </LinearLayout>

                <!-- VS -->
                <TextView
                    android:id="@+id/tvScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="8dp"
                    android:text="VS"
                    android:textColor="#111827"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <!-- 원정팀 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/imgAwayLogo"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:scaleType="centerCrop"
                        android:contentDescription="원정 팀 로고"
                        android:src="@drawable/ic_placeholder_circle"
                        app:shapeAppearanceOverlay="@style/RoundedImageStyle"
                        app:strokeColor="@android:color/transparent" />

                    <TextView
                        android:id="@+id/tvAwayName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Team1"
                        android:textColor="#111827"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:gravity="center" />
                </LinearLayout>
            </LinearLayout>

            <!-- 장소 / 주소 -->
            <TextView
                android:id="@+id/tvPlace"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="대치유수지축구장"
                android:textAlignment="center"
                android:textColor="#111827"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvAddress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="2dp"
                android:text="서울특별시 강남구 대치동 역삼로107길 20-30 대치유수지체육공원"
                android:textAlignment="center"
                android:textColor="#6B7280"
                android:textSize="12sp" />
        </LinearLayout>
    </FrameLayout>
</com.google.android.material.card.MaterialCardView>
